# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

require 'base64'

default_platform(:ios)

platform :ios do
  desc "Build and test on simulator"
  lane :test do
    run_tests(
      scheme:         "JumpTuner",
      destination:    "platform=iOS Simulator,OS=latest,name=iPhone 17 Pro",
      result_bundle:  true
    )
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: "JumpTuner.xcodeproj"
    )
    build_app(scheme: "JumpTuner")
    upload_to_testflight
  end

  desc "Build a PR branch and upload to TestFlight for review"
  lane :pr_beta do
    pr_number = ENV.fetch("PR_NUMBER", "0")
    pr_title  = ENV.fetch("PR_TITLE",  "PR build")

    # Install provisioning profile
    profile_b64 = ENV["PROVISIONING_PROFILE_BASE64"]
    UI.user_error!("PROVISIONING_PROFILE_BASE64 secret is not set") if profile_b64.nil? || profile_b64.empty?
    profile_path = "/tmp/profile.mobileprovision"
    File.binwrite(profile_path, Base64.decode64(profile_b64))
    install_provisioning_profile(path: profile_path)

    api_key = app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
      xcodeproj:    "JumpTuner.xcodeproj"
    )

    build_app(
      scheme:        "JumpTuner",
      export_method: "app-store",
      xcargs:        "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='JumpTunerDist'",
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        provisioningProfiles: { "visceralorigami.JumpTuner" => "JumpTunerDist" }
      }
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "PR ##{pr_number}: #{pr_title}"
    )
  end
end
